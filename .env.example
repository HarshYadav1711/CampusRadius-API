# --- HTTP ---
PORT=3000
# Bind address (default 0.0.0.0 — required for most cloud hosts to accept external traffic)
BIND_HOST=0.0.0.0

# development | production — use production on hosted demos so errors stay generic in responses
NODE_ENV=development

# --- MySQL (DB_HOST, DB_USER, DB_NAME required — empty DB_PASSWORD allowed locally) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=campus_radius
DB_POOL_LIMIT=10

# TLS for hosted MySQL (set true when your provider requires encrypted connections)
DB_SSL=false
# Only if the provider’s docs say so for demo/dev (disables certificate hostname verification — avoid in real prod)
# DB_SSL_REJECT_UNAUTHORIZED=false

# --- CORS ---
# Single origin URL, or * for open access during local/demo testing
CORS_ORIGIN=*

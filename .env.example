# --- HTTP ---
PORT=3000
# Bind address (default 0.0.0.0 — required for most cloud hosts to accept external traffic)
BIND_HOST=0.0.0.0

# development | production — use production on hosted demos so errors stay generic in responses
NODE_ENV=development

# --- MySQL (DB_HOST, DB_USER, DB_NAME required — empty DB_PASSWORD allowed locally) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=campus_radius
DB_POOL_LIMIT=10

# TLS for hosted MySQL (required for Aiven and most cloud providers)
DB_SSL=false
# Only if the provider’s docs say so for demo/dev (disables certificate hostname verification — avoid in real prod)
# DB_SSL_REJECT_UNAUTHORIZED=false

# --- Example: Aiven MySQL (values from Aiven console; DB_NAME is often defaultdb) ---
# DB_HOST=mysql-xxxxx.your-region.aivencloud.com
# DB_PORT=15122
# DB_USER=avnadmin
# DB_PASSWORD=your-password
# DB_NAME=defaultdb
# DB_SSL=true
# Managed DB already has a database (e.g. Aiven defaultdb): skip CREATE DATABASE
# SKIP_CREATE_DATABASE=true

# --- CORS ---
# Single origin URL, or * for open access during local/demo testing
CORS_ORIGIN=*
